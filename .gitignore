# --- Generated VM / disk images & appliances ---
*.ova
*.img
*.ext2
*.ext4
*.qcow2
*.iso
*.vmdk

# --- Browser-lab build artifacts ---
browser-lab/build/
browser-lab/dist/
browser-lab/image/dist/         # generated fs.json / flat/ / rootfs.tar
browser-lab/image/payload/      # staged player files copied in at image-build time
# (browser-lab/vendor/* — the ~9.6MB vendored kernel blob — is ignored by browser-lab/vendor/.gitignore)

# --- Wordlists (full lists only; build/wordlists/trimmed.txt IS shipped) ---
rockyou.txt
rockyou*.txt
*.wordlist
wordlists/full/

# --- Build scratch (stage-deploy.sh default dest: build/scratch/lab/deploy) ---
build/scratch/

# --- OS / editor / language cruft ---
.DS_Store
**/.DS_Store
__pycache__/
*.pyc
.venv/
node_modules/
*.log
