#!/bin/bash
# ============================================================================
#  Chiral Lab — minimal init (PID 1) for the v86 serial console.
# ============================================================================
# debian-slim ships no init system, and full systemd is slow + finicky under
# v86 emulation. This tiny init is all the lab needs: bring up the pseudo-
# filesystems, then hand the player an interactive shell on ttyS0. The kernel
# boots with `console=ttyS0 init=/sbin/lab-init`, so PID 1's stdio is already
# the serial console the browser terminal is wired to.
export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
export HOME=/root TERM=xterm USER=root LOGNAME=root

mount -t proc     proc /proc    2>/dev/null
mount -t sysfs    sys  /sys     2>/dev/null
mount -t devtmpfs dev  /dev     2>/dev/null
mount -t tmpfs    tmp  /tmp      2>/dev/null
mount -t tmpfs    run  /run      2>/dev/null
mount -o remount,rw / 2>/dev/null
hostname chiral-lab 2>/dev/null

cat /etc/motd 2>/dev/null
# Plain ASCII dash: the serial console isn't UTF-8, so an em dash prints as "â".
printf '\nChiral Lab - your challenge files are in ~/challenges.\n'
printf 'Read a briefing to begin, e.g.:  cat BRIEF-01-photo-day.md\n\n'
cd /root/challenges 2>/dev/null || cd /root

# Keep respawning the shell so an accidental `exit` (or Ctrl-D) doesn't leave
# PID 1 dead and the box wedged. setsid -c gives the shell a controlling tty
# on ttyS0 so job control (Ctrl-C, &, fg) works.
while true; do
  setsid -c /bin/bash -i
  printf '\n[lab] shell exited — restarting. (Use the toolbar Reset for a clean box.)\n'
  sleep 1
done
